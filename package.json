{
  "name": "thailand-data-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Thailand data: DBD company registry lookup, Thai address normalization, holidays, and VAT/WHT reference",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narinthon-so/thailand-data-mcp.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "thailand",
    "thai-address",
    "dbd",
    "company-registry",
    "ai-agents"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "thailand-data-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "apify": "^3.2.6",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
